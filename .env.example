# Persistência: "json" (padrão, usa data/*.json) ou "supabase"
# PERSISTENCE=json

# Supabase (obrigatório quando PERSISTENCE=supabase e para login/cadastro)
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# Chave pública: obrigatória para autenticação (login, cadastro, recuperação de senha).
# No Dashboard: Settings → API → "anon" public (não use a service_role aqui).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key  # apenas scripts/migração; não usar no fluxo da app

# Opcional: diretório dos JSON quando PERSISTENCE=json
# DATA_DIR=./data
